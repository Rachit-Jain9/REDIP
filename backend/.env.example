NODE_ENV=development
PORT=5000

# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/redevint

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Supabase Configuration (for file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_STORAGE_BUCKET=redevint-documents

# Geocoding API Key (Nominatim - free, or use Google Maps API key)
GEOCODING_API_KEY=your-geocoding-api-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip
