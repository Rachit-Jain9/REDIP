NODE_ENV=development
PORT=5000

# PostgreSQL (Supabase pooler — Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=generate-with-node-crypto-randomBytes-48-hex
JWT_EXPIRES_IN=7d

# Supabase (Storage — file uploads; use SERVICE ROLE key here, server-side only)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=redip-documents

# Vercel Blob (primary document storage — preferred)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Maps (server-side geocoding — Geocoding API must be enabled)
GOOGLE_MAPS_API_KEY=AIzaSy...

# Picovoice (voice interface)
PICOVOICE_ACCESS_KEY=your-picovoice-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://redip.vercel.app
